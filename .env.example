# Configuración de Secretos para Baby Project Manager
# Copia este archivo como '.env' y añade tu URL de Webhook de Discord

# URL del Webhook de Discord para reportes directos
# Puedes crear uno en: Ajustes del Servidor -> Integraciones -> Webhooks
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/TU_WEBHOOK_AQUI
